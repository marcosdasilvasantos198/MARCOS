//+------------------------------------------------------------------+\n//| AI Market Heat Predictor v2.0                                   |\n//| Indicador Avançado com IA e Previsão de Notícias                |\n//| Combina: RSI, MACD, Estocástico, Bollinger, Volume, IA         |\n//+------------------------------------------------------------------+\n\n#property indicator_chart_window\n#property indicator_buffers 5\n#property indicator_plots 5\n\n#property indicator_label1 "Compra Forte"\n#property indicator_type1 DRAW_ARROW\n#property indicator_color1 clrLime\n#property indicator_width1 2\n\n#property indicator_label2 "Venda Forte"\n#property indicator_type2 DRAW_ARROW\n#property indicator_color2 clrRed\n#property indicator_width2 2\n\n#property indicator_label3 "Força do Sinal"\n#property indicator_type3 DRAW_LINE\n#property indicator_color3 clrYellow\n#property indicator_width3 2\n\n#property indicator_label4 "Confiança IA"\n#property indicator_type4 DRAW_LINE\n#property indicator_color4 clrCyan\n#property indicator_width4 2\n\n#property indicator_label5 "Sentimento Notícias"\n#property indicator_type5 DRAW_LINE\n#property indicator_color5 clrMagenta\n#property indicator_width5 2\n\n// BUFFERS\ndouble BuyBuffer[];\ndouble SellBuffer[];\ndouble SignalStrengthBuffer[];\ndouble AIConfidenceBuffer[];\ndouble NewsSentimentBuffer[];\n\n// INPUT PARAMETERS\ninput int RSIPeriod = 14;\ninput int RSIOverbought = 70;\ninput int RSIOversold = 30;\n\ninput int MacdFastEMA = 12;\ninput int MacdSlowEMA = 26;\ninput int MacdSignalSMA = 9;\n\ninput int StochKPeriod = 14;\ninput int StochDPeriod = 3;\n\ninput int BollingerPeriod = 20;\ninput double BollingerDeviation = 2.0;\n\ninput int VolumePeriod = 14;\ninput int FastMA = 20;\ninput int SlowMA = 50;\n\n// INDICATOR HANDLES\nint rsiHandle, macdHandle, stochHandle, bbHandle, maFastHandle, maSlowHandle;\n\n//+------------------------------------------------------------------+\n//| INICIALIZAÇÃO\n//+------------------------------------------------------------------+\nint OnInit() {\n    SetIndexBuffer(0, BuyBuffer);\n    SetIndexBuffer(1, SellBuffer);\n    SetIndexBuffer(2, SignalStrengthBuffer);\n    SetIndexBuffer(3, AIConfidenceBuffer);\n    SetIndexBuffer(4, NewsSentimentBuffer);\n    \n    PlotIndexSetInteger(0, PLOT_ARROW, 241); // Seta para cima\n    PlotIndexSetInteger(1, PLOT_ARROW, 242); // Seta para baixo\n    \n    // Criar handles dos indicadores\n    rsiHandle = iRSI(_Symbol, _Period, RSIPeriod, PRICE_CLOSE);\n    macdHandle = iMACD(_Symbol, _Period, MacdFastEMA, MacdSlowEMA, MacdSignalSMA, PRICE_CLOSE);\n    stochHandle = iStochastic(_Symbol, _Period, StochKPeriod, StochDPeriod, 3, MODE_SMA, STO_LOWHIGH);\n    bbHandle = iBands(_Symbol, _Period, BollingerPeriod, BollingerDeviation, 0, PRICE_CLOSE);\n    maFastHandle = iMA(_Symbol, _Period, FastMA, 0, MODE_EMA, PRICE_CLOSE);\n    maSlowHandle = iMA(_Symbol, _Period, SlowMA, 0, MODE_EMA, PRICE_CLOSE);\n    \n    if(rsiHandle == INVALID_HANDLE || macdHandle == INVALID_HANDLE || \n       stochHandle == INVALID_HANDLE || bbHandle == INVALID_HANDLE ||\n       maFastHandle == INVALID_HANDLE || maSlowHandle == INVALID_HANDLE) {\n        Alert("Erro ao criar handles dos indicadores!");\n        return INIT_FAILED;\n    }\n    \n    return INIT_SUCCEEDED;\n}\n\n//+------------------------------------------------------------------+\n//| CÁLCULO PRINCIPAL\n//+------------------------------------------------------------------+\nint OnCalculate(const int rates_total,\n                const int prev_calculated,\n                const datetime &time[],\n                const double &open[],\n                const double &high[],\n                const double &low[],\n                const double &close[],\n                const long &tick_volume[],\n                const long &volume[],\n                const int &spread[]) {\n    \n    if(rates_total < 50) return 0;\n    \n    // COPIAR DADOS DOS INDICADORES\n    double rsi[],macdLine[], macdSignal[], macdHist[];\n    double stochMain[], stochSignal[];\n    double bbUpper[], bbMiddle[], bbLower[];\n    double maFast[], maSlow[];\n    \n    ArraySetAsSeries(rsi, true);\n    ArraySetAsSeries(macdLine, true);\n    ArraySetAsSeries(macdSignal, true);\n    ArraySetAsSeries(macdHist, true);\n    ArraySetAsSeries(stochMain, true);\n    ArraySetAsSeries(stochSignal, true);\n    ArraySetAsSeries(bbUpper, true);\n    ArraySetAsSeries(bbMiddle, true);\n    ArraySetAsSeries(bbLower, true);\n    ArraySetAsSeries(maFast, true);\n    ArraySetAsSeries(maSlow, true);\n    \n    CopyBuffer(rsiHandle, 0, 0, rates_total, rsi);\n    CopyBuffer(macdHandle, 0, 0, rates_total, macdLine);\n    CopyBuffer(macdHandle, 1, 0, rates_total, macdSignal);\n    CopyBuffer(macdHandle, 2, 0, rates_total, macdHist);\n    CopyBuffer(stochHandle, 0, 0, rates_total, stochMain);\n    CopyBuffer(stochHandle, 1, 0, rates_total, stochSignal);\n    CopyBuffer(bbHandle, 1, 0, rates_total, bbUpper);\n    CopyBuffer(bbHandle, 2, 0, rates_total, bbMiddle);\n    CopyBuffer(bbHandle, 3, 0, rates_total, bbLower);\n    CopyBuffer(maFastHandle, 0, 0, rates_total, maFast);\n    CopyBuffer(maSlowHandle, 0, 0, rates_total, maSlow);\n    \n    // PROCESSAR CADA CANDLE\n    int limit = (prev_calculated > 0) ? prev_calculated - 1 : rates_total - 1;\n    \n    for(int i = limit; i >= 1; i--) {\n        // CALCULAR FORÇA DO SINAL (0-100)\n        double signalStrength = CalculateSignalStrength(\n            rsi[i], macdLine[i], macdSignal[i], macdHist[i],\n            stochMain[i], stochSignal[i],\n            bbUpper[i], bbLower[i], close[i],\n            maFast[i], maSlow[i],\n            volume[i], VolumePeriod\n        );\n        \n        // CALCULAR CONFIANÇA DA IA (baseado em convergência de indicadores)\n        double aiConfidence = CalculateAIConfidence(\n            rsi[i], macdHist[i], stochMain[i],\n            maFast[i], maSlow[i]\n        );\n        \n        // PREVER SENTIMENTO DE NOTÍCIAS (simulado)\n        double newsSentiment = PredictNewsSentiment(i, close[i], high[i], low[i]);\n        \n        // APLICAR LÓGICA DE ENTRADA\n        if(signalStrength > 70 && aiConfidence > 65) {\n            // SINAL DE COMPRA FORTE\n            if(rsi[i] > RSIOversold && rsi[i] < RSIOverbought &&\n               macdHist[i] > 0 && maFast[i] > maSlow[i] &&\n               stochMain[i] > stochSignal[i]) {\n                \n                BuyBuffer[i] = low[i] - 20 * _Point;\n                SellBuffer[i] = EMPTY_VALUE;\n                \n                if(i == 1) Alert("🟢 COMPRA FORTE! Força: ", signalStrength, "% | IA: ", aiConfidence, "% | Notícias: ", newsSentiment);\n            }\n        }\n        else if(signalStrength > 70 && aiConfidence > 65) {\n            // SINAL DE VENDA FORTE\n            if(rsi[i] > RSIOversold && rsi[i] < RSIOverbought &&\n               macdHist[i] < 0 && maFast[i] < maSlow[i] &&\n               stochMain[i] < stochSignal[i]) {\n                \n                SellBuffer[i] = high[i] + 20 * _Point;\n                BuyBuffer[i] = EMPTY_VALUE;\n                \n                if(i == 1) Alert("🔴 VENDA FORTE! Força: ", signalStrength, "% | IA: ", aiConfidence, "% | Notícias: ", newsSentiment);\n            }\n        }\n        else {\n            BuyBuffer[i] = EMPTY_VALUE;\n            SellBuffer[i] = EMPTY_VALUE;\n        }\n        \n        SignalStrengthBuffer[i] = signalStrength;\n        AIConfidenceBuffer[i] = aiConfidence;\n        NewsSentimentBuffer[i] = newsSentiment;\n    }\n    \n    return rates_total;\n}\n\n//+------------------------------------------------------------------+\n//| CALCULAR FORÇA DO SINAL (0-100)\n//+------------------------------------------------------------------+\ndouble CalculateSignalStrength(\n    double rsi, double macdLine, double macdSignal, double macdHist,\n    double stochK, double stochD,\n    double bbUpper, double bbLower, double close,\n    double maFast, double maSlow,\n    long volume, int volPeriod) {\n    \ndouble strength = 0;\n    \n    // RSI - Força do Momentum (0-20 pontos)\n    if(rsi > 50) strength += (rsi - 50) * 0.4; // até 20\n    else strength += (50 - rsi) * 0.4;\n    \n    // MACD - Confirmação de Tendência (0-20 pontos)\n    if(macdHist > 0) strength += 10;\n    if(macdLine > macdSignal) strength += 10;\n    \n    // Estocástico - Força Adicional (0-20 pontos)\n    if(stochK > stochD) strength += 10;\n    if(stochK > 50) strength += 10;\n    \n    // Médias Móveis - Tendência (0-20 pontos)\n    if(maFast > maSlow) strength += 20;\n    \n    // Bollinger Bands - Volatilidade (0-20 pontos)\n    double bbRange = bbUpper - bbLower;\n    if(close > (bbLower + bbRange * 0.7)) strength += 15;\n    \n    return MathMin(strength, 100);\n}\n\n//+------------------------------------------------------------------+\n//| CALCULAR CONFIANÇA DA IA (0-100)\n//+------------------------------------------------------------------+\ndouble CalculateAIConfidence(double rsi, double macdHist, double stochK, double maFast, double maSlow) {\n    double confidence = 50; // Base 50%\n    \n    // Se todos indicadores convergem\n    if(macdHist > 0 && stochK > 50 && maFast > maSlow) confidence += 25;\n    else if(macdHist < 0 && stochK < 50 && maFast < maSlow) confidence += 25;\n    else confidence -= 10;\n    \n    // RSI fora de extremos = mais confiável\n    if(rsi > 35 && rsi < 65) confidence += 15;\n    \n    return MathMin(confidence, 100);\n}\n\n//+------------------------------------------------------------------+\n//| PREVER SENTIMENTO DE NOTÍCIAS (Simulado com IA)\n//+------------------------------------------------------------------+\ndouble PredictNewsSentiment(int candle, double close, double high, double low) {\n    // Simular previsão de notícias com análise de volatilidade\n    double range = high - low;\n    double sentiment = 50; // Neutro\n    \n    if(range > close * 0.02) sentiment += 20; // Alta volatilidade = possível notícia\n    if(close > open) sentiment += 10; // Fechamento para cima\n    \n    return MathMin(MathMax(sentiment, 0), 100);\n}\n\n//+------------------------------------------------------------------+\n//| DEINIT\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason) {\n    IndicatorRelease(rsiHandle);\n    IndicatorRelease(macdHandle);\n    IndicatorRelease(stochHandle);\n    IndicatorRelease(bbHandle);\n    IndicatorRelease(maFastHandle);\n    IndicatorRelease(maSlowHandle);\n}